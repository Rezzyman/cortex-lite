# CORTEX Lite Configuration
# -------------------------
# No config needed if Ollama is running locally with mxbai-embed-large.
# Just run: ollama pull mxbai-embed-large

# Embedding provider (auto-detected if not set)
# CORTEX_EMBEDDING_PROVIDER=ollama    # ollama | voyage | openai

# Ollama settings (defaults shown)
# OLLAMA_URL=http://localhost:11434
# CORTEX_EMBEDDING_MODEL=mxbai-embed-large

# API providers (optional — set key to enable)
# VOYAGE_API_KEY=pa-...
# OPENAI_API_KEY=sk-...
